#!/usr/bin/env bash
# SessionStart hook for the AgentCorp plugin.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

router_content=$(cat "${PLUGIN_ROOT}/hooks/agentcorp-router.md" 2>&1 || echo "Error reading AgentCorp router context")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Codex has no SessionEnd: sweep stale Stop-hook state files (see hooks/codex-stop-capture).
# A session whose last turn is >30 min old is over — run its capture analysis now, detached.
codex_state_dir="${PLUGIN_ROOT}/teamspace/skill-evolution/.codex-sessions"
if [ -d "$codex_state_dir" ]; then
    find "$codex_state_dir" -maxdepth 1 -type f -mmin +30 2>/dev/null | while IFS= read -r state_file; do
        stale_transcript="$(sed -n '1p' "$state_file" 2>/dev/null)"
        stale_session="$(basename "$state_file")"
        rm -f "$state_file" 2>/dev/null || true
        [ -n "$stale_transcript" ] && [ -f "$stale_transcript" ] || continue
        "${SCRIPT_DIR}/run-capture-analysis" "$stale_session" "$stale_transcript" "codex-stale-sweep" || true
    done
fi

# Skill-evolution: surface any pending improvement proposals so the human knows (人类可知).
pending_dir="${AGENTCORP_EVOLUTION_DIR:-${PLUGIN_ROOT}/teamspace/skill-evolution/pending}"
combined_content="$router_content"
if [ -d "$pending_dir" ]; then
    pending_count=$(find "$pending_dir" -maxdepth 1 -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
    if [ "${pending_count:-0}" -gt 0 ]; then
        combined_content="[AgentCorp skill-evolution] ${pending_count} 条 skill 改进提案待审，见 teamspace/skill-evolution/pending/ —— 用 skill-evolution 处理（起草 → 人审 → 落地）。

${router_content}"
    fi
fi

router_escaped=$(escape_for_json "$combined_content")
session_context="<AGENTCORP_SESSION_CONTEXT>\n${router_escaped}\n</AGENTCORP_SESSION_CONTEXT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
