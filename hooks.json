{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd session-start",
            "async": false
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd session-end-capture",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/run-hook.cmd user-prompt-heartbeat",
            "async": false
          }
        ]
      }
    ]
  }
}
