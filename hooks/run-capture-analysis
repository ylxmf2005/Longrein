#!/usr/bin/env bash
# Shared skill-evolution capture runner for the AgentCorp plugin.
#
# Spawns the detached transcript analysis that turns a finished session into reviewable
# proposals under teamspace/skill-evolution/pending/. Called by session-end-capture
# (Claude Code, at SessionEnd) and by the session-start stale sweep (Codex, which has no
# SessionEnd event). It never edits a skill; proposals go through the `skill-evolution` gate.
#
# Usage: run-capture-analysis SESSION_ID TRANSCRIPT_PATH END_REASON
# Runs on whichever CLI the host exposes: `claude -p`, falling back to `codex exec`.

set -uo pipefail

# Re-entrancy guard: the analysis runs a CLI that can fire hooks again.
[ -n "${AGENTCORP_EVOLUTION_CAPTURE:-}" ] && exit 0
[ "${AGENTCORP_EVOLUTION_DISABLE:-}" = "1" ] && exit 0

SESSION_ID="${1:-session}"
TRANSCRIPT="${2:-}"
REASON="${3:-}"

[ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ] || exit 0
SESSION_ID="${SESSION_ID//[^A-Za-z0-9_-]/-}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PROMPT_FILE="${SCRIPT_DIR}/skill-evolution-analyze.md"
[ -f "$PROMPT_FILE" ] || exit 0

OUT_DIR="${AGENTCORP_EVOLUTION_DIR:-${PLUGIN_ROOT}/teamspace/skill-evolution/pending}"
LOG_DIR="${PLUGIN_ROOT}/teamspace/skill-evolution/.logs"
mkdir -p "$OUT_DIR" "$LOG_DIR" 2>/dev/null || exit 0

# Pick the analysis CLI from what the host actually exposes.
RUNNER=""
if command -v claude >/dev/null 2>&1; then
    RUNNER="claude"
elif command -v codex >/dev/null 2>&1; then
    RUNNER="codex"
else
    exit 0
fi

# Fire-and-forget: the caller (a lifecycle hook) must return instantly.
(
  prompt="$(cat "$PROMPT_FILE")

SESSION_ID: ${SESSION_ID}
TRANSCRIPT_PATH: ${TRANSCRIPT}
END_REASON: ${REASON}"
  if [ "$RUNNER" = "claude" ]; then
    result="$(AGENTCORP_EVOLUTION_CAPTURE=1 claude -p "$prompt" 2>"${LOG_DIR}/${SESSION_ID}.err")"
  else
    result="$(AGENTCORP_EVOLUTION_CAPTURE=1 codex exec "$prompt" 2>"${LOG_DIR}/${SESSION_ID}.err")"
  fi
  if [ -n "$result" ] && ! printf '%s' "$result" | grep -q "NO_PROPOSALS"; then
    ts="$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%s)"
    printf '%s\n' "$result" > "${OUT_DIR}/${ts}-${SESSION_ID}.md"
  fi
) </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true

exit 0
