#!/usr/bin/env bash
# SessionEnd hook for the AgentCorp plugin — skill-evolution capture.
#
# When an AgentCorp session ends, scan the just-finished transcript for signals that a skill
# could be improved (or that external research should become a new skill) and write reviewable
# PROPOSALS into teamspace/skill-evolution/pending/. It never edits a skill: the human reviews
# proposals next session (the SessionStart hook surfaces the pending count) and lands them
# through the normal gates (the `skill-evolution` skill).
#
# Fire-and-forget: the heavy analysis is spawned detached and the hook returns immediately, so
# it never blocks session teardown or hits the SessionEnd timeout budget.
#
# Opt out with AGENTCORP_EVOLUTION_DISABLE=1. Override the output dir with AGENTCORP_EVOLUTION_DIR.

set -uo pipefail

# Re-entrancy guard: the background analysis runs `claude`, which can fire this hook again.
[ -n "${AGENTCORP_EVOLUTION_CAPTURE:-}" ] && exit 0
[ "${AGENTCORP_EVOLUTION_DISABLE:-}" = "1" ] && exit 0

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

PAYLOAD="$(cat)"
PARSED="$(printf '%s' "$PAYLOAD" | python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    d = {}
for k in ("transcript_path", "session_id", "cwd", "reason"):
    print(d.get(k, "") or "")
' 2>/dev/null)" || exit 0

TRANSCRIPT="$(printf '%s\n' "$PARSED" | sed -n '1p')"
SESSION_ID="$(printf '%s\n' "$PARSED" | sed -n '2p')"
REASON="$(printf '%s\n' "$PARSED" | sed -n '4p')"

# Need a real transcript to analyze.
[ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ] || exit 0
[ -n "$SESSION_ID" ] || SESSION_ID="session"
# Sanitize: SESSION_ID is used in output/log file names, so never let it escape the directory.
SESSION_ID="${SESSION_ID//[^A-Za-z0-9_-]/-}"

# Gate: only sessions where AgentCorp was actually active. The SessionStart router injects the
# marker AGENTCORP_SESSION_CONTEXT, so its presence is a cheap, reliable relevance signal that
# keeps cost and noise off unrelated sessions.
grep -q "AGENTCORP_SESSION_CONTEXT" "$TRANSCRIPT" 2>/dev/null || exit 0

# The CLI must exist to run the analysis; degrade silently if not.
command -v claude >/dev/null 2>&1 || exit 0

PROMPT_FILE="${SCRIPT_DIR}/skill-evolution-analyze.md"
[ -f "$PROMPT_FILE" ] || exit 0
REDACTOR="${SCRIPT_DIR}/redact-skill-evolution.py"
[ -f "$REDACTOR" ] || exit 0
OUT_DIR="${AGENTCORP_EVOLUTION_DIR:-${PLUGIN_ROOT}/teamspace/skill-evolution/pending}"
LOG_DIR="${PLUGIN_ROOT}/teamspace/skill-evolution/.logs"
mkdir -p "$OUT_DIR" "$LOG_DIR" 2>/dev/null || exit 0

# Fire-and-forget so SessionEnd returns instantly; the analysis runs detached.
(
  prompt="$(cat "$PROMPT_FILE")

SESSION_ID: ${SESSION_ID}
TRANSCRIPT_PATH: ${TRANSCRIPT}
END_REASON: ${REASON}"
  result="$(AGENTCORP_EVOLUTION_CAPTURE=1 claude -p "$prompt" 2>"${LOG_DIR}/${SESSION_ID}.err")"
  redacted="$(printf '%s' "$result" | python3 "$REDACTOR")" || exit 0
  if [ -n "$redacted" ] && ! printf '%s' "$redacted" | grep -q "NO_PROPOSALS"; then
    ts="$(date -u +%Y%m%dT%H%M%SZ 2>/dev/null || date +%s)"
    printf '%s\n' "$redacted" > "${OUT_DIR}/${ts}-${SESSION_ID}.md"
  fi
) </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true

exit 0
